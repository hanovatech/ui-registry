{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "sheet-form",
	"title": "Sheet Form",
	"type": "registry:block",
	"description": "Slide-over sheets for detail views and forms with sections.",
	"dependencies": [
		"@lucide/svelte"
	],
	"devDependencies": [
		"@lucide/svelte@^1.7.0"
	],
